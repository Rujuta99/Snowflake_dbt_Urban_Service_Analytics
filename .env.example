# Copy this file to ".env" and fill in values as needed.
# Everything here is OPTIONAL for Phase 1 -- the ingestion works without any of it.

# Optional Socrata app token. Anonymous access works but is rate-limited.
# Get one free: data.cityofchicago.org -> sign in -> Developer Settings -> create app token.
# SOCRATA_APP_TOKEN=your_token_here

# Override the dataset id only if the city migrates the dataset.
# SOCRATA_DATASET_ID=v6vf-nfxy

# Override where raw files land (defaults to data/bronze/sr_311).
# BRONZE_DIR=data/bronze/sr_311
